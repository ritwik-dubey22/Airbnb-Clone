<% layout ('/layouts/boilerplate') %>


    <div class="row  mt-3">
        <div class="col-6  offset-3">
            <h1 class="text-center text-primary fw-bold fs-3">log into WanderLust</h1>
            <form action="/login" method="POST" class="needs-validation" novalidate>




                <div class="mb-3"> <label for="username" class="form-label">username
                </label>

                    <input name="username" placeholder="enter  your username" type="text" class="form-control" required id="username">
                    <div class="valid-feedback">Nice username..</div>
                </div>





                <div class="mb-3"> <label for="password" class="form-label">
                </label>

                    <input name="password" placeholder="enter your password" type="password" class="form-control " required id="password">

                </div>




                <button class="btn btn-primary w-100 fw-bold">Log in </button>
            </form>
        </div>
    </div>