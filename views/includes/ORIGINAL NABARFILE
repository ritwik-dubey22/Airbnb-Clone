<style>
    .btn-search {
        background-color: #fe424d;
        color: aliceblue;
        border-radius: 19px;
        padding: 0 1rem 0 1rem;
    }
    
    .btn-search:hover {
        background-color: #fe424d;
        color: aliceblue;
    }
    
    .btn-search i {
        display: inline-block;
        /* allows margin to work properly */
        margin-right: 1rem;
        /* 3rem is usually too much */
    }
    
    .search-input {
        border-radius: 19px;
        padding: 0.5rem 3rem 0.5rem 3;
    }
    /* Search button */
    
    .btn-danger {
        background-color: #ff385c;
        border-color: #ff385c;
    }
    
    .btn-danger:hover {
        background-color: #ff385c;
        border-color: #ff385c;
        opacity: 0.9;
        transition: 0.3s;
    }
    /* Rounded input field */
    
    .form-control {
        border-radius: 50px !important;
    }
    /* Focus effect */
    
    .input-group .form-control:focus {
        box-shadow: 0 0 0 0.2rem rgba(255, 56, 92, 0.25);
        border-color: #ff385c;
    }
</style>
