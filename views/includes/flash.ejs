<!-- sucees>0 -->

<% if (success && success.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show mt-4 px-4 py-3 fw-semibold shadow-lg rounded-3 border-start border-5 border-success text-center" role="alert">
        ✅
        <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>





        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger  alert-dismissible fade show mt-4 px-4 py-3 fw-semibold shadow-lg rounded-3 border-start border-5 border-success text-center" role="alert">

                <%= error   %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <% } %>