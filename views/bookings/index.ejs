<% layout ('/layouts/boilerplate') %>

    <body>
        <div class="container mt-5 mb-5">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10">
                    <h2 class="fw-bold mb-4">Your Bookings</h2>

                    <% if (!bookings || bookings.length === 0) { %>
                        <div class="alert alert-info">You haven't made any bookings yet. <a href="/listings">Explore listings</a> to make your first booking!</div>
                        <% } else { %>
                            <div class="list-group">
                                <% bookings.forEach((booking) => { %>
                                    <div class="list-group-item mb-3 shadow-sm rounded">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h5 class="mb-1">
                                                    <a href="/listings/<%= booking.listing._id %>">
                                                        <%= booking.listing.title %>
                                                    </a>
                                                </h5>
                                                <p class="mb-1 text-muted">Booked on
                                                    <%= booking.createdAt.toLocaleDateString() %>
                                                </p>
                                            </div>
                                            <span class="badge bg-primary rounded-pill">₹ <%= booking.totalPrice.toLocaleString('en-IN') %></span>
                                        </div>
                                        <div class="mt-3">
                                            <p class="mb-1"><strong>Check-in:</strong>
                                                <%= booking.checkIn.toLocaleDateString() %>
                                            </p>
                                            <p class="mb-1"><strong>Check-out:</strong>
                                                <%= booking.checkOut.toLocaleDateString() %>
                                            </p>
                                            <p class="mb-0"><strong>Nights:</strong>
                                                <%= booking.nights %>
                                            </p>
                                        </div>
                                        <div class="mt-3 d-flex justify-content-end">
                                            <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel Booking</button>
                                            </form>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                            <% } %>
                </div>
            </div>
        </div>
    </body>