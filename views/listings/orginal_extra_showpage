                            </form>
                        </div>
                    </div> -->
                </div>

                <!-- <hr>
                <h4> All Review</h4>
                <ul>
                    <%for(review of listing_show.reviews){  %>
                        <li>
                            <%= review.Comment  %>,
                                <%=review.rating %>
                        </li>


                        <% } %>
                </ul> -->

            </div>

            <hr>
            <h4 class="mb-4">All Reviews</h4>

            <div class="row">
                <% listing_show.reviews.forEach((review, index) => { %>
                    <div class="col-md-6 mb-3">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex align-items-start">

                                <!-- LEFT: Random Realistic User Image -->
                                <img src="https://i.pravatar.cc/100?img=<%= Math.floor(Math.random() * 70) + 1 %>" class="rounded-circle me-3" width="80" height="80" style="object-fit: cover;" alt="user">

                                <!-- RIGHT: Comment + Username -->
                                <div class="flex-grow-1">
                                    <% if(review.username && review.username.trim() !== "") { %>
                                        <h6 class="card-subtitle mb-1 text-muted">
                                            <%= review.username %>
                                        </h6>
                                        <% } %>

                                            <% if(review.Comment && review.Comment.trim() !== "") { %>
                                                <p class="card-text mb-2">
                                                    <%= review.Comment %>
                                                </p>
                                                <% } %>

                                                    <!-- Rating BELOW comment -->
                                                    <span class="badge bg-success">
              ⭐ <%= review.rating %>/5
            </span>
                                </div>

                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>


        </div>
    </body>


    </html>