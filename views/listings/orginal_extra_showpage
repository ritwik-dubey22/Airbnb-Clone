<!-- using the ejs-mate -->
<% layout ('/layouts/boilerplate') %>


    <body>
        <div class="row">
            <div class="col-8  offset-2 mt-4">
                <h3>
                    <%= listing_show.title %>
                </h3>


                <div class="card show-page-img  mt-5"><img src="<%= listing_show.image.url %>" class="card-img-top" alt="single listing img">
                    <div class="card-body">
                        <h5 class="card-title"></h5>
                        <p class="card-text">
                            <br>

                            <%= listing_show.description %> <br> &#8377;
                                <%= listing_show.price
    ? listing_show.price.toLocaleString("en-IN")
    : "N/A"
%>
                                    <br>
                                    <%= listing_show.location %> <br>
                                        <%= listing_show.country %>
                        </p>

                    </div>
                </div>
                <div class="btns-show-page mb-5">
                    <a href="/listings/<%= listing_show._id %>/edit" class="  btn btn-edit btn-primary  offset-0.1"> Edit</a>
                    <br><br>
                    <form method="POST" action="/listings/<%= listing_show._id %>?_method=DELETE">
                        <button class="offset-11 btn-delete  btn  btn-primary">Delete</button></form>




                    <!-- REVIEW SECTION ALIGNED WITH LISTING CARD -->
                    <div class="row">
                        <div class="mb-5 mt-5" style="width: 100%; padding: 0 15px;">
                            <br> <br>
                            <h4>Review Section</h4>
                            <form action="/listings/<%= listing_show.id  %>/reviews" method="POST" class="needs-validation" novalidate>
                                <div class="mb-3 mt-3">
                                    <label for="rating" class="form-label">Rating</label>
                                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range w-100">
                                </div>

                                <div class="mb-3 mt-3">
                                    <label for="comment" class="form-label">Comments</label>
                                    <textarea id="comment" cols="30" rows="5" class="form-control w-100" name="review[Comment]" required></textarea>
                                    <div class="invalid-feedback">enter some comments for review</div>
                                </div>

                                <button class="btn  btn-light hover-bg-dark-black">Submit</button>
                            </form>
                        </div>
                    </div>



