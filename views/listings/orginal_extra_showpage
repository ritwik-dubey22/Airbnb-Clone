                        <div class="col-8  offset-3 mb-3">

                            <h4> Review Section</h4>
                            <form>

                                <div class="mb-3  mt-3">
                                    <label for="rating" class="form-label">Rating</label>


                                    <input type="range" min="1" max="5" id="rating" name="review[rating]">
