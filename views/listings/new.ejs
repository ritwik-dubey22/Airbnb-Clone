<!-- using the ejs-mate -->
<% layout ('/layouts/boilerplate') %>


    <body>
        <br>
        <div class="row">
            <div class="col-8 offset-2">

                <h1>Create New Listing</h1>
                <br><br>
                <!-- action me listingsrkhne se ham wapis listing wle route par aa jyenge -->
                <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

                    <div class="mb-3"> <label for="title" class="form-label">Title
                </label>

                        <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required>
                        <div class="valid-feedback">Title looks good...</div>
                    </div>

                    <br> <br>

                    <div class="mb-3"><label for="description" class="description" class="from-label">enter description
                </label>

                        <textarea name="listing[description]" placeholder="enter description" type="text" class="form-control" required> </textarea>


                    </div>


                    <br> <br>


                    <div class="mb-3">

                        <label for="image" class="form-label">Upload listing images
                </label>

                        <input id="listingImages" required name="images" placeholder="enter images" type="file" class="form-control" multiple accept="image/*">
                        <div id="imageCount" class="form-text text-muted">No images selected.</div>
                    </div>


                    <br> <br>
                    <div class="row">
                        <div class="mb-3 col-md-3"> <label for="price" class="form-label">enter price
                </label>

                            <input required name="listing[price]" placeholder="enter price" class="form-control">
                            <div class="invalid-feedback">enter a valid price </div>
                        </div>

                        <br> <br>
                        <div class="mb-3 col-8">
                            <label for="country" class="form-label">enter country
                </label>

                            <input required class="form-control" name="listing[country]" placeholder="india" type="text">
                            <div class="invalid-feedback">enter a valid country name</div>
                        </div>
                    </div> <br> <br>
                    <div class="mb-3">
                        <label for="location" class="form-label">enter location/address
                </label>

                        <input required class="form-control" name="listing[location]" placeholder="enter location/address" type="text">
                        <div class="invalid-feedback">enter a valid location</div>

                    </div><br><br>

                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select name="listing[category]" class="form-control" required>
    <option value="">Select Category</option>
    <option value="trending">Trending</option>
    <option value="rooms">Rooms</option>
    <option value="villa">Villa</option>
    <option value="cities">Iconic Cities</option>
    <option value="mountain">Mountain</option>
    <option value="winter">Winter</option>
    <option value="beach">Beach</option>
    <option value="forest">Forest</option>
    <option value="sunny">Sunny</option>
</select>
                    </div>
                    <button class="btn add-btn">Add</button>


                </form>
                <script>
                    const listingImagesInput = document.getElementById('listingImages');
                    const imageCount = document.getElementById('imageCount');
                    if (listingImagesInput) {
                        listingImagesInput.addEventListener('change', () => {
                            const count = listingImagesInput.files.length;
                            imageCount.textContent = count > 0 ? `${count} image${count === 1 ? '' : 's'} selected.` : 'No images selected.';
                        });
                    }
                </script>
                <br><br> <br> <br> </body>
    </div>

    </div>